# Crypto Intelligence AI Platform — Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# asyncpg for SQLAlchemy async engine
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/crypto_intelligence
# psycopg2 for Alembic migrations (synchronous)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@localhost:5432/crypto_intelligence

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── CoinGecko ─────────────────────────────────────────────────────────────────
COINGECKO_API_URL=https://api.coingecko.com/api/v3
# Optional: free tier works without key, but rate limits are tighter
COINGECKO_API_KEY=

# ── News APIs ─────────────────────────────────────────────────────────────────
NEWS_API_KEY=
CRYPTOPANIC_API_KEY=

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000
SECRET_KEY=change-me-to-a-random-secret-key
