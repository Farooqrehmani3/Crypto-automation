# ── Supabase (REQUIRED — set on Vercel) ──────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → Data API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Backend API (REQUIRED — set on Vercel) ────────────────────────────
# Use your Railway deployment URL (not localhost)
NEXT_PUBLIC_API_URL=https://your-app.railway.app

# ── App (REQUIRED — set on Vercel) ────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_NAME=Crypto Intelligence AI

# ── Stripe (server-side only) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── OpenAI (server-side only — NEVER prefixed with NEXT_PUBLIC_) ───────
OPENAI_API_KEY=sk-...
