# Crypto Intelligence AI Platform — Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → Data API
SUPABASE_URL=https://your-project.supabase.co
# The anon/publishable key (safe for client-side). Starts with "sb_publishable_".
SUPABASE_ANON_KEY=sb_publishable_...
# The service_role (secret) key for backend operations. Starts with "sb_secret_".
# This bypasses Row-Level Security — NEVER expose it client-side.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
# Used as fallback for manual JWT verification. Found in Project Settings → Data API.
SUPABASE_JWT_SECRET=your-jwt-secret

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# asyncpg for SQLAlchemy async engine
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres
# psycopg2 for Alembic migrations (synchronous)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── CoinGecko ─────────────────────────────────────────────────────────────────
COINGECKO_API_URL=https://api.coingecko.com/api/v3
# Optional: free tier works without key, but rate limits are tighter
COINGECKO_API_KEY=

# ── News APIs ─────────────────────────────────────────────────────────────────
NEWS_API_KEY=
CRYPTOPANIC_API_KEY=

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
# Comma-separated list of allowed CORS origins. Add your Vercel domain here!
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
SECRET_KEY=change-me-to-a-random-secret-key

# ── Admin ─────────────────────────────────────────────────────────────────────
# Credentials for the admin panel at /admin/login
ADMIN_USERNAME=admin@tecflux.com
ADMIN_PASSWORD=Office@1
